TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=attic
DB_PASSWORD=attic_password
DB_DATABASE=attic

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue (defaults to same Redis)
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434

# Qdrant
QDRANT_HOST=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=attic_knowledge_base

# FalkorDB (config-gated, requires --profile full)
FALKORDB_ENABLED=false
FALKORDB_HOST=127.0.0.1
FALKORDB_PORT=6380

# Python sidecar (requires --profile full)
SIDECAR_URL=http://127.0.0.1:8100
