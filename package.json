    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.26.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "ts-node-maintained": "^10.9.6",
    "typescript": "~5.8",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0",
