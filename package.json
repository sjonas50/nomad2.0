    "@adonisjs/transmit": "^3.0.1",
    "@adonisjs/vite": "^5.1.0",
    "@inertiajs/react": "^2.3.18",
    "@qdrant/js-client-rest": "^1.17.0",
    "@rlanz/bull-queue": "^3.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@vinejs/vine": "^3.0.1",
    "dockerode": "^4.0.10",
    "edge.js": "^6.2.1",
    "falkordb": "^6.6.2",
    "luxon": "^3.7.2",
    "mysql2": "^3.20.0",
    "ollama": "^0.6.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
